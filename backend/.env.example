# --- Database (F12) ---
# asyncpg URL, e.g. postgresql+asyncpg://user:pass@localhost:5432/campus_rag
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/campus_rag
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# 0 = pgbouncer/session-pooler safe (disables asyncpg prepared-statement cache).
# Set >0 only for a direct (non-pooled) connection.
DB_STATEMENT_CACHE_SIZE=0
DB_ECHO=false

# --- Seed admin (F12) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Auth (F10) ---
# Required, no default. Rotating it invalidates every issued token. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
# JWT_ALGORITHM=HS256
# JWT_LEEWAY_S=30
# ACCESS_TOKEN_TTL_MIN=15
# REFRESH_TOKEN_TTL_DAYS=7
# BCRYPT_ROUNDS=12
# AUTH_EMAIL_DOMAIN_ALLOWLIST=["edu.pk"]
# LOGIN_MAX_FAILURES=10
# LOGIN_LOCKOUT_WINDOW_MIN=15
# RATE_LIMIT_ANON_PER_MIN=5
# RATE_LIMIT_STUDENT_PER_MIN=20
# RATE_LIMIT_ADMIN_PER_MIN=60
# RATE_LIMIT_API_KEY_PER_MIN=30

# --- Retrieval enhancement flags (F5–F9, F17) ---
# Code defaults are all `false` so every eval label stays reproducible from a bare checkout.
# Turning a layer on is a DEPLOYMENT decision made here, not in settings.py.
#
# Rerank + compression are on for local/prod: they are the layers whose `stage` events the UI
# shows, and with them off the pipeline trail reads "reranking — skipped".
# Rerank loads a CPU cross-encoder (~90MB, first call downloads it) and adds ~200-300ms.
ENABLE_RERANK=true
ENABLE_COMPRESSION=true
# Query rewrite stays OFF: it regressed headline hit@5 in the F7 eval (docs/eval_results/).
# ENABLE_QUERY_REWRITE=false
# ENABLE_HYBRID=false
# ENABLE_CACHE=false
# ENABLE_MEMORY=false

# --- Ingestion (F1) --- all optional; defaults below are relative to the `backend/` cwd.
# DATA_DIR=app/data
# RAW_DIR=app/data/raw
# EXTRACTED_DIR=app/data/extracted
# SOURCES_CSV=app/data/sources.csv
# INGEST_CONCURRENCY=4
# INGEST_RATE_LIMIT_PER_SEC=1.0
# INGEST_MAX_RETRIES=3
# INGEST_DOWNLOAD_TIMEOUT_S=60.0
# OCR_LANGUAGES=eng+urd
# OCR_MIN_PAGE_TEXT_CHARS=50
# OCR_SCANNED_PAGE_THRESHOLD=0.30
# CLEAN_HEADER_FOOTER_PAGE_RATIO=0.60
# CLEAN_MIN_BLOCK_CHARS=20
# LIBREOFFICE_BIN=libreoffice

# --- Chunking & Indexing (F2) ---
OPENAI_API_KEY=sk-change-me
PINECONE_API_KEY=pc-change-me
PINECONE_INDEX=campus-rag
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIM=1536
# EMBED_BATCH_SIZE=100
# EMBED_CONCURRENCY=4
# EMBED_MAX_RETRIES=5
# EMBED_MAX_CHUNK_TOKENS=8000
# PINECONE_UPSERT_CONCURRENCY=4
# PINECONE_METADATA_MAX_BYTES=40000
# INDEXING_STRATEGY=fixed
# FIXED_CHUNK_TOKENS=500
# FIXED_CHUNK_OVERLAP=50
# STRUCTURE_MAX_SECTION_TOKENS=800
# BM25_PATH=app/data/bm25.pkl
# INDEX_MANIFEST_PATH=app/data/index_manifest.json
