# --- Secrets / environment ---
.env
.env.*
!.env.example
# Build-mode config, not a secret: `vite build --mode mock` reads it to produce the MSW-backed
# bundle the Lighthouse gate runs against.
!frontend/.env.mock

# --- Python (backend) ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Node / React+Vite frontend ---
node_modules/
frontend/dist/
frontend/build/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Ingestion / indexing artifacts (regenerable, not source) ---
backend/app/data/raw/
backend/app/data/extracted/
backend/app/data/*.pkl
backend/app/data/*.jsonl

# --- Local infra state ---
docker/**/*.env
*.db
*.sqlite3
postgres-data/
redis-data/

# --- Logs ---
*.log
logs/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
